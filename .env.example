# Eluide Voter Portal — Environment Variables
# Copy this file to .env and fill in your values.

# Google Gemini API Key (required for AI assistant)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (optional — for enhanced location features)
VITE_MAPS_API_KEY=your_maps_api_key_here

# Firebase API Key (optional — for analytics and auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
